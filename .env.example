# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=flashdev
DB_USER=flashdev
DB_PASS=flashdev_secret

# Admin seed account (used by SeedService on startup)
ADMIN_EMAIL=admin@flashdev.io
ADMIN_PASSWORD=FlashDev2026!

# JWT
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_different_strong_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
PORT=3001
NODE_ENV=development

# Web
VITE_API_URL=http://localhost:3001/api
WEB_URL=http://localhost:5173

# Google OAuth (optional for v0.01)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Cloudflare R2 (optional for v0.01)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=flashdev-gameweb
R2_PUBLIC_URL=

# Email (optional for v0.01)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
