{
  "name": "flashdev-gameweb",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run build:shared && bun run --cwd apps/api start:dev",
    "build:web": "bun run --cwd apps/web build",
    "build:api": "bun run build:shared && bun run --cwd apps/api build",
    "build:shared": "bun run --cwd packages/shared build",
    "test": "bun run --filter './apps/*' test",
    "db:up": "docker compose up -d db"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "multer": "^2.2.0"
  }
}
